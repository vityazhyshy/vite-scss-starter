{
    "name": "vite-scss-starter",
    "version": "2.0.0",
    "private": true,
    "description": "Modern multipage frontend starter powered by Vite and Sass",
    "author": "Andrey Gorokhov",
    "license": "GPL-3.0-only",
    "repository": {
        "type": "git",
        "url": "https://github.com/vityazhyshy/vite-scss-starter.git"
    },
    "scripts": {
        "dev": "vite --host 127.0.0.1",
        "build": "vite build",
        "build:no-hash": "NO_HASH=true vite build",
        "preview": "vite preview --host 127.0.0.1",
        "assets:prepare": "node ./scripts/assets.mjs prepare",
        "assets:sprites": "node ./scripts/assets.mjs sprites",
        "assets:images": "node ./scripts/assets.mjs images",
        "assets:webp": "node ./scripts/assets.mjs webp",
        "assets:favicons": "node ./scripts/assets.mjs favicons",
        "build:sprites": "npm run assets:sprites",
        "build:images": "npm run assets:images",
        "build:webp": "npm run assets:webp",
        "build:favicons": "npm run assets:favicons",
        "block": "node ./scripts/generate-block.mjs",
        "block:module": "node ./scripts/generate-block.mjs --type=module",
        "block:component": "node ./scripts/generate-block.mjs --type=component",
        "bem-m": "node ./scripts/generate-block.mjs --type=module",
        "bem-c": "node ./scripts/generate-block.mjs --type=component",
        "new:page": "node ./scripts/generate-page.mjs",
        "lint": "npm run lint:js && npm run lint:styles",
        "lint:fix": "npm run lint:js -- --fix && npm run lint:styles -- --fix",
        "lint:js": "eslint .",
        "lint:scripts": "npm run lint:js",
        "lint:scripts:fix": "npm run lint:js -- --fix",
        "lint:styles": "stylelint \"src/**/*.{scss,css}\"",
        "lint:styles:fix": "npm run lint:styles -- --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,mjs}": [
            "eslint --fix"
        ],
        "*.{scss,css}": [
            "stylelint --fix"
        ],
        "*.{html,json,md}": [
            "prettier --write"
        ]
    },
    "engines": {
        "node": ">=18.20.0"
    },
    "packageManager": "npm@10.7.0",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "autoprefixer": "^10.4.21",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "fast-glob": "^3.3.3",
        "favicons": "^7.2.0",
        "globals": "^15.15.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.2",
        "postcss": "^8.5.8",
        "prettier": "^3.6.2",
        "sass": "^1.98.0",
        "sharp": "^0.34.4",
        "stylelint": "^16.26.1",
        "stylelint-config-standard-scss": "^13.1.0",
        "svg-sprite": "^2.0.4",
        "svgo": "^4.0.0",
        "vite": "^5.4.21",
        "vitest": "^2.1.9"
    }
}
